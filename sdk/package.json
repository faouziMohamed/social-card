{
  "name": "social-card-sdk",
  "version": "0.1.3",
  "description": "TypeScript SDK for Social Card — generate OG images, badges, and SEO assets via API",
  "homepage": "https://social-card.mfaouzi.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/faouziMohamed/social-card.git",
    "directory": "sdk"
  },
  "bugs": {
    "url": "https://github.com/faouziMohamed/social-card/issues"
  },
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "clean": "rimraf dist",
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "example": "tsx examples/demo.ts",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "og-image",
    "open-graph",
    "social-cards",
    "badges",
    "seo",
    "meta-tags",
    "typescript",
    "sdk"
  ],
  "author": "Mohamed Faouzi <me@mfaouzi.com>",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-unicorn": "^64.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.5.0",
    "prettier": "^3.8.3",
    "prettier-plugin-organize-imports": "^4.3.0",
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.5"
  }
}
